# Telegram API credentials from https://my.telegram.org
TG_API_ID=123456
TG_API_HASH=replace_with_api_hash
TG_PHONE=+91xxxxxxxxxx

# Legacy comma-separated Telegram source usernames/IDs.
# Used only when SOURCES_CONFIG_PATH does not exist or contains no sources.
SOURCE_CHATS=@source_channel_1,@source_channel_2

# Source intelligence config. Prefer sources.yaml for per-source routing and thresholds.
SOURCES_CONFIG_PATH=sources.yaml

# Private channel/group/user where saved signals should be posted by default.
DESTINATION_CHAT=@your_private_signal_channel
DEST_DEFAULT_CHAT=

# Optional category-specific destinations. Empty values fall back to DESTINATION_CHAT.
DEST_CAREER_CHAT=
DEST_AI_ENGINEERING_CHAT=
DEST_RESEARCH_CHAT=
DEST_TEACHING_CHAT=
DEST_CONTENT_CHAT=
DEST_TOOLS_CHAT=
DEST_ENGLISH_CHAT=
DEST_GLOBAL_ECONOMY_CHAT=
DEST_OTHER_CHAT=

# Optional separate channel for daily briefings. Defaults to DESTINATION_CHAT when empty.
BRIEFING_CHAT=

# LLM backend: ollama or opencode
LLM_PROVIDER=ollama

# Ollama settings used when LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# OpenCode settings used when LLM_PROVIDER=opencode
# Example model format depends on your OpenCode provider setup, such as anthropic/claude-sonnet-4-5 or openai/gpt-5.5.
OPENCODE_MODEL=
# Optional: run `opencode serve` separately, then set this to avoid cold starts.
# Example: http://localhost:4096
OPENCODE_ATTACH_URL=
OPENCODE_TIMEOUT_SECONDS=180

# Scoring behavior
MIN_SAVE_SCORE=7.0
MAX_MESSAGE_CHARS=5000

# Local database
DATABASE_PATH=data/signals.db

# Telethon local session name. Do not commit generated .session files.
TELEGRAM_SESSION_NAME=tele_scraper_brain
